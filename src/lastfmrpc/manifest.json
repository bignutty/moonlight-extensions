{
  "$schema": "https://moonlight-mod.github.io/manifest.schema.json",
  "id": "lastFmRpc",
  "version": "1.0.0",
  "apiLevel": 2,
  "meta": {
    "name": "Last.fm Rich Presence",
    "tagline": "Adds last.fm rich presence",
    "description": "Last.fm Rich Presence with links to Gramophone, an alternative Last.fm frontend.",
    "authors": ["bignutty","90-008"],
    "source": "https://github.com/bignutty/moonlight-extensions/tree/main/src/lastfmrpc",
    "tags": ["profiles"]
  },
  "dependencies": ["spacepack", "common"],
  "settings": {
    "username": {
      "displayName": "Username",
      "type": "string",
      "description": "Your Last.fm username"
    },
    "apiKey": {
      "displayName": "API key",
      "type": "string",
      "description": "Your Last.fm API key. If you don't have an api key, create one [here](https://www.last.fm/api/account/create)."
    },
    "shareUsername": {
      "displayName": "Share username",
      "type": "boolean",
      "default": false,
      "description": "Show link to your Last.fm profile"
    },
    "shareSong": {
      "displayName": "Share song",
      "type": "boolean",
      "default": true,
      "description": "Show link to song on Last.fm"
    },
    "hideWithSpotify": {
      "displayName": "Hide if listening on Spotify",
      "type": "boolean",
      "default": true,
      "description": "Hide Last.fm rich presence when Spotify is playing"
    },
    "hideWithActivity": {
      "displayName": "Hide if other activity",
      "type": "boolean",
      "default": false,
      "description": "Hide Last.fm rich presence if you have any other presence"
    },
    "statusName": {
      "displayName": "Custom status text",
      "description": "Added after Listening to / Playing",
      "type": "string",
      "default": "some music"
    },
    "nameFormat": {
      "displayName": "Status text format",
      "type": "select",
      "options": [
        { "value": "status-name", "label": "use custom status text" },
        { "value": "artist-first", "label": "Use 'artist - song' format" },
        { "value": "song-first", "label": "Use 'song - artist' format" },
        { "value": "artist", "label": "Use artist name only" },
        { "value": "song", "label": "Use song name only" },
        {
          "value": "album",
          "label": "Use album name (fallbacks to custom status text if song is not part of an album)"
        }
      ],
      "default": "status-name"
    },
    "useListeningStatus": {
      "displayName": "Use listening status",
      "type": "boolean",
      "default": true,
      "description": "Show 'Listening to' status instead of 'Playing'"
    },
    "updateInterval": {
      "displayName": "Update interval",
      "type": "number",
      "default": 10,
      "description": "Seconds to wait between fetching now playing and updating presence",
      "advice": "restart"
    },
    "correctionsData": {
      "displayName": "Corrections data",
      "type": "string",
      "description": "Paste the contents of your Gramophone [corrections export](https://gramophone.bignut.zip/settings/corrections/manage) file here to apply artist corrections. Leave empty to clear."
    }
  }
}